---
import CourseLayout from '../../layouts/CourseLayout.astro';
import CaseContent from '../../components/CaseContent';
import { courseData, getProblemById } from '../../data/course';

export function getStaticPaths() {
  return courseData.problems.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const problem = getProblemById(id);

if (!problem) {
  return Astro.redirect('/');
}
---

<CourseLayout title={problem.title}>
  <!-- Breadcrumbs -->
  <nav class="flex items-center gap-1.5 text-sm text-text-muted mb-6 flex-wrap">
    <a href="/" class="hover:text-text-primary transition-colors">Главная</a>
    <span>/</span>
    <span class="hover:text-text-primary transition-colors">Разбор кейсов</span>
    <span>/</span>
    <span class="text-text-secondary">{problem.title}</span>
  </nav>

  <!-- Case label -->
  <p class="text-xs font-bold uppercase tracking-wider text-accent-indigo mb-3">
    Разбор кейса
  </p>

  <!-- Case title -->
  <h1 class="text-2xl sm:text-3xl font-bold text-text-primary">
    {problem.title}
  </h1>

  <!-- Interactive case content -->
  <CaseContent client:load problem={problem} />
</CourseLayout>
