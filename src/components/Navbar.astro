---
import SearchWidget from './SearchWidget';
---

<header class="sticky top-0 z-50 border-b border-border bg-bg-primary/80 backdrop-blur-md">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent-indigo to-accent-purple flex items-center justify-center text-white font-bold text-sm">
        S
      </div>
      <span class="font-semibold text-text-primary">
        SysDesign<span class="text-accent-indigo">.online</span>
      </span>
    </a>

    <!-- Nav links (hidden on mobile) -->
    <div class="hidden sm:flex items-center gap-5 flex-1">
      <a href="/#program" class="text-sm hover:text-text-primary transition-colors">Программа</a>
      <a href="/#authors" class="text-sm hover:text-text-primary transition-colors">Авторы</a>
      <a href="/bookmarks" class="text-sm hover:text-text-primary transition-colors">Закладки</a>
      <a href="https://github.com/arazkevich/sysdesign-course" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-text-primary transition-colors">GitHub</a>
    </div>

    <!-- Search -->
    <SearchWidget client:load />
  </nav>
</header>
