---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ModuleCardsGrid from '../components/ModuleCardsGrid';
import ProblemCard from '../components/ProblemCard.astro';
import Footer from '../components/Footer.astro';
import { courseData } from '../data/course';
---

<Layout title="Материалы курса">
  <Navbar />

  <main>
    <!-- Page header -->
    <section class="py-10 border-b border-border">
      <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-3xl font-extrabold text-text-primary mb-2">Материалы курса</h1>
        <p class="text-text-muted">46 уроков · 7 тестов · 5 кейсов</p>
      </div>
    </section>

    <!-- Modules grid -->
    <section class="py-12">
      <div class="max-w-6xl mx-auto px-4">
        <ModuleCardsGrid client:load />
      </div>
    </section>

    <!-- Case studies -->
    <section class="py-16 border-t border-border">
      <div class="max-w-6xl mx-auto px-4">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-text-primary mb-2">Разбор кейсов</h2>
          <p class="text-text-secondary">Реальные задачи системного проектирования с детальным разбором</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {courseData.problems.map((problem) => (
            <ProblemCard problem={problem} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
