---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SearchWidget from '../components/SearchWidget';
---

<Layout title="Поиск по курсу">
  <Navbar />
  <main class="max-w-2xl mx-auto px-4 py-16 flex flex-col items-center gap-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-text-primary">Поиск по курсу</h1>
    <div class="w-full">
      <SearchWidget client:load />
    </div>
    <p class="text-sm text-text-muted text-center">
      Введите не менее 2 символов для поиска по модулям и урокам
    </p>
  </main>
</Layout>
